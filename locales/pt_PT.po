msgstr "Ferramentas de teste"

msgid "Send test notification (all users)"
msgstr "Enviar notificação de teste (todos os utilizadores)"

msgid "Clear test notifications"
msgstr "Limpar notificações de teste"

msgid "Run cron now"
msgstr "Correr cron agora"

msgid "Force notification (all future reservations)"
msgstr "Forçar notificação (todas as reservas futuras)"

