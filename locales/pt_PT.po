msgstr "Crontab do sistema"

msgid "Checking crontab status..."
msgstr "A verificar estado do crontab..."

msgid "exec() is disabled on this server."
msgstr "exec() desativado neste servidor."

msgid "Install the crontab manually over SSH using the command below."
msgstr "Instale o crontab manualmente via SSH com o comando abaixo."

