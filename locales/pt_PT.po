msgstr "Agora"

msgid "Unknown item"
msgstr "Item desconhecido"

msgid "Table %s does not exist."
msgstr "A tabela %s não existe."

msgid "The plugin needs to be reinstalled: Setup > Plugins > Disable > Enable."
msgstr "O plugin precisa de ser reinstalado: Configurar > Plugins > Desativar > Ativar."

msgid "Unknown action."
msgstr "Ação desconhecida."

msgid "Cron task not found. Reinstall the plugin (disable and enable it)."
msgstr "Cron task não encontrado. Reinstale o plugin (desativar e ativar)."

msgid "Send alerts for reservations starting soon"
msgstr "Enviar alertas para reservas a iniciar em breve"

msgid "crontab exited with code %s"
msgstr "o crontab terminou com código %s"

msgid "The crontab command is not available on this server."
msgstr "O comando crontab não está disponível neste servidor."

msgid "Active (external scheduler)"
msgstr "Ativo (scheduler externo)"

msgid "Cron is running anyway (last run: %s) — handled by the container/system scheduler, no crontab entry needed."
msgstr "O cron está a correr na mesma (última execução: %s) — gerido pelo scheduler do container/sistema, não é precisa entrada no crontab."
