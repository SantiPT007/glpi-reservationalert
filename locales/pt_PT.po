msgstr "A correr cron..."

msgid "Result:"
msgstr "Resultado:"

msgid "Reservations found in the %s-minute window:"
msgstr "Reservas encontradas na janela de %s min:"

msgid "Current server time:"
msgstr "Hora atual do servidor:"

